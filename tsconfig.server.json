{
  "compilerOptions": {
    "outDir": "dist/server",
    "module": "node16",
    "moduleResolution": "node16",
    "target": "ES2022",
    "esModuleInterop": true,
       "skipLibCheck": true,
    "strict": true,
    "resolveJsonModule": true,
    "sourceMap": false,
    "types": ["node"]
  },
  "include": ["server/**/*.ts"]
}
