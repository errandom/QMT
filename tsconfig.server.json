{
  "compilerOptions": {
    "outDir": "dist/server",
    "module": "Node16",
    "moduleResolution": "Node16",
    "target": "ES2022",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "strict": true,
    "resolveJsonModule": true,
    "sourceMap": false,
    "types": ["node"],
    "allowSyntheticDefaultImports": true
  },
  "include": ["server/**/*.ts"]
}
